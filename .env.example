# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Yellowstone gRPC (Helius/Triton)
GRPC_ENDPOINT=https://your-grpc-endpoint.com
GRPC_TOKEN=your-grpc-token

# Jito Block Engine
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
JITO_TIP_LAMPORTS=10000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-chat-id

# API Keys
GOPLUS_API_KEY=
RUGCHECK_API_URL=https://api.rugcheck.xyz/v1

# Jupiter (get API key at https://portal.jup.ag)
JUPITER_API_URL=https://api.jup.ag/swap/v1
JUPITER_API_KEY=

# Security (REQUIRED — generate salt with: openssl rand -base64 32)
ENCRYPTION_SALT=
WALLET_PASSWORD=

# Database
DATABASE_PATH=data/ricoz-sniper.db

# Risk Management
MAX_BUY_SOL=1.0
MAX_POSITIONS=10
DAILY_LOSS_LIMIT_SOL=5.0
DEFAULT_SLIPPAGE_BPS=500
TRADE_COOLDOWN_SECS=30
MIN_SCORE_AUTO_BUY=75
MIN_SCORE_NOTIFY=50

# Network
USE_DEVNET=false
